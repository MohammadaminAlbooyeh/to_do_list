{
  "expo": {
    "name": "doflow",
    "slug": "doflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1d1d1f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doflow.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1d1d1f"
      },
      "package": "com.doflow.app"
    },
    "web": {
      "build": {
        "entry": "./web/index.web.js"
      }
    }
  }
}
